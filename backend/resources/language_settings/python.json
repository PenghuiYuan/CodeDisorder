{
  "$schema": "../language_settings.schema.json",
  "language": "python",
  "display": "Python",
  "file_extension": "py",
  "verify_command": null,
  "verify_use": "ast.parse",
  "reserved": [
    "False", "None", "True", "and", "as", "assert", "async", "await", "break",
    "class", "continue", "def", "del", "elif", "else", "except", "finally",
    "for", "from", "global", "if", "import", "in", "is", "lambda", "nonlocal",
    "not", "or", "pass", "raise", "return", "try", "while", "with", "yield",
    "self", "cls", "print", "len", "range", "enumerate", "zip", "map",
    "filter", "sum", "min", "max", "abs", "round", "sorted", "reversed",
    "list", "dict", "set", "tuple", "str", "int", "float", "bool", "bytes",
    "object", "type", "isinstance", "issubclass", "callable", "iter", "next",
    "open", "input", "repr", "id", "hash", "dir", "vars", "globals", "locals",
    "any", "all", "super", "property", "staticmethod", "classmethod",
    "__init__", "__new__", "__del__", "__repr__", "__str__", "__len__",
    "__getitem__", "__setitem__", "__iter__", "__next__", "__call__",
    "__enter__", "__exit__", "__name__", "__main__", "__file__", "__doc__",
    "__class__", "__dict__", "__module__", "__all__", "__annotations__",
    "__slots__", "__contains__", "__add__", "__sub__", "__mul__", "__eq__",
    "__lt__", "__gt__", "__le__", "__ge__", "__ne__", "__hash__"
  ],
  "rename_targets": [
    "Name", "FunctionDef", "AsyncFunctionDef", "ClassDef", "arg"
  ],
  "include_cursor_kinds": ["Import", "ImportFrom"]
}
