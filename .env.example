# Sample environment for docker-compose. Copy to ``.env`` and edit.
#
# ``stdio``  — Worker processes are spawned by the API via stdio JSON-RPC.
#              Use this in production. Workers crash independently.
# ``import`` — Worker transformers are imported in-process. Faster startup,
#              no spawn overhead, no real isolation. Use in dev.
WORKER_MODE=stdio

# Python logging level for the API process.
# One of: debug, info, warning, error.
LOG_LEVEL=info
